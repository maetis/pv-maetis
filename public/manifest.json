{
  "name": "PV Maétis",
  "short_name": "PV Maétis",
  "description": "Transcription et procès-verbal de séance — Association Maétis",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#F7F5F2",
  "theme_color": "#2A6049",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", "video/*", ".m4a", ".mp3", ".wav", ".ogg", ".aac", ".caf", ".webm"]
        }
      ]
    }
  }
}
